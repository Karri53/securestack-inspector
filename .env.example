# .env.example
# ----------------------------------------------------------------------
# This is the TEMPLATE for environment variables. It gets committed to git
# so anyone cloning the repo knows what they need to configure.
# The REAL values live in .env (which is gitignored). Run:
#     cp .env.example .env
# then fill in any real secrets locally.
# ----------------------------------------------------------------------

# ---- Postgres ----
POSTGRES_USER=securestack
POSTGRES_PASSWORD=changeme_in_local_env
POSTGRES_DB=securestack
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development
# For production, generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=dev_secret_replace_in_prod

# ---- Frontend ----
# The Next.js app needs to know where the API lives. In Docker this is the
# service name; in the browser it's localhost because the browser runs outside
# the Docker network.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Logging ----
LOG_LEVEL=INFO